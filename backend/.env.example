# Chave pública anon (Settings → API → anon public)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave secreta service_role (Settings → API → service_role) — NÃO expor no frontend
